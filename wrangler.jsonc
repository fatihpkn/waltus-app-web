{
  "compatibility_date": "2026-04-19",
  "compatibility_flags": ["global_fetch_strictly_public"],
  "name": "waltus-app-web",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },
  "vars": {
    "PUBLIC_OPENPANEL_CLIENT_ID": "",
  },
  "observability": {
    "enabled": true,
  },
}
