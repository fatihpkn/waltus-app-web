---
import { Icon } from 'astro-icon/components';
---

<section class="py-32 px-6 bg-surface">
  <div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-20">
    <!-- Left: Clarity card -->
    <div class="lg:w-1/2 order-2 lg:order-1">
      <div class="rounded-2xl overflow-hidden editorial-shadow bg-surface-container-lowest dark:border dark:border-white/5">
        <div class="p-8 border-b border-surface-container-low dark:border-white/5 flex items-center justify-between">
          <h4 class="font-bold text-on-surface">Deterministic Clarity</h4>
          <Icon name="material-symbols:verified-outline" class="w-6 h-6 text-primary dark:text-indigo-400" />
        </div>
        <div class="p-12 space-y-10">
          <div class="flex gap-6">
            <div class="w-12 h-12 shrink-0 rounded-full bg-primary/10 dark:bg-primary/20 flex items-center justify-center">
              <Icon name="material-symbols:question-mark" class="w-6 h-6 text-primary dark:text-indigo-400" />
            </div>
            <div class="space-y-2">
              <div class="text-lg font-bold text-on-surface">"Why did my balance change?"</div>
              <p class="text-on-surface-variant">Instead of showing a raw number, Waltus highlights the delta with human explanation.</p>
            </div>
          </div>
          <div class="relative bg-surface-container-low rounded-xl p-8 space-y-4 dark:border dark:border-white/5">
            <div class="flex justify-between items-end">
              <div>
                <div class="text-xs uppercase font-bold text-on-surface-variant mb-1">Impact</div>
                <div class="text-2xl font-bold text-error">-$45.00</div>
              </div>
              <div class="text-right">
                <div class="text-xs uppercase font-bold text-on-surface-variant mb-1">Reason</div>
                <div class="text-sm font-medium text-on-surface">Automatic Subscription</div>
              </div>
            </div>
            <div class="h-1 bg-surface-variant dark:bg-surface-container-highest rounded-full overflow-hidden">
              <div class="w-3/4 h-full bg-primary dark:bg-indigo-500 rounded-full"></div>
            </div>
            <p class="text-sm text-on-surface-variant italic">"This matches your typical monthly burn for Entertainment services."</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Right: Copy -->
    <div class="lg:w-1/2 order-1 lg:order-2 space-y-8">
      <h2 class="text-5xl font-extrabold tracking-tight leading-tight text-on-surface">
        Every penny, <br />accounted for.
      </h2>
      <p class="text-xl text-on-surface-variant leading-relaxed">
        Anxiety stems from the unknown. We built Waltus to answer the "Why" before you even have to ask.
        Our deterministic clarity engine explains every transaction in plain English.
      </p>
      <ul class="space-y-4 list-none p-0 m-0">
        <li class="flex items-start gap-3">
          <Icon name="material-symbols:check-circle-outline" class="w-6 h-6 text-primary dark:text-indigo-400 mt-1 shrink-0" />
          <div>
            <strong class="block text-on-surface">Auto-Labeling</strong>
            <span class="text-on-surface-variant">We decode vendor IDs into recognizable business names.</span>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <Icon name="material-symbols:check-circle-outline" class="w-6 h-6 text-primary dark:text-indigo-400 mt-1 shrink-0" />
          <div>
            <strong class="block text-on-surface">Delta Analysis</strong>
            <span class="text-on-surface-variant">Instantly see what changed since you last opened the app.</span>
          </div>
        </li>
      </ul>
    </div>
  </div>
</section>
