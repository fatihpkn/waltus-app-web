---
import { Icon } from 'astro-icon/components';
---

<section class="pt-40 pb-24 px-6 overflow-hidden bg-surface">
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <!-- Left: Copy -->
    <div class="space-y-8">
      <h1 class="text-6xl md:text-7xl font-extrabold tracking-tight leading-[1.05] text-on-surface">
        Finance with <br /><span class="text-primary">total clarity.</span>
      </h1>
      <p class="text-xl text-on-surface-variant max-w-lg leading-relaxed">
        Understand every movement of your money. No more cryptic codes or delayed balances—just the absolute truth of your financial life.
      </p>
      <div class="flex flex-wrap gap-4 pt-4">
        <button
          class="px-8 py-4 rounded-full primary-gradient text-white font-bold text-lg editorial-shadow transition-transform hover:scale-[1.02] active:scale-95 cursor-pointer"
          data-track="cta_clicked"
          data-location="hero"
          data-cta="get-started"
        >
          Get Started
        </button>
        <button class="px-8 py-4 rounded-full bg-surface-container-high text-primary font-bold text-lg transition-transform hover:scale-[1.02] active:scale-95 flex items-center gap-2 cursor-pointer">
          <Icon name="material-symbols:play-circle" class="w-6 h-6" />
          Watch the Film
        </button>
      </div>
    </div>

    <!-- Right: Phone mockup -->
    <div class="relative">
      <div class="relative z-10 w-full max-w-[320px] mx-auto lg:ml-auto">
        <div class="bg-surface-container-lowest dark:bg-surface-container-lowest rounded-[3rem] p-4 editorial-shadow ring-8 ring-on-surface/5 dark:ring-white/5">
          <div class="bg-surface-container-low rounded-[2.5rem] overflow-hidden aspect-[9/19] flex flex-col dark:border dark:border-white/5">
            <!-- Mockup Header -->
            <div class="p-6 pb-2">
              <div class="flex justify-between items-center mb-6">
                <div class="w-8 h-8 rounded-full bg-primary/10 dark:bg-primary/20 flex items-center justify-center">
                  <Icon name="material-symbols:person-outline" class="w-4 h-4 text-primary dark:text-indigo-400" />
                </div>
                <Icon name="material-symbols:notifications-outline" class="w-6 h-6 text-on-surface-variant" />
              </div>
              <div class="space-y-1">
                <span class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Total Balance</span>
                <div class="text-3xl font-bold text-on-surface">$42,920.50</div>
              </div>
            </div>
            <!-- Mockup Transaction List -->
            <div class="flex-1 p-4 space-y-3 bg-white dark:bg-surface-container-lowest mt-4 rounded-t-3xl overflow-hidden dark:border-t dark:border-white/5">
              <div class="p-3 bg-surface-container-low rounded-xl flex items-center justify-between dark:border dark:border-white/5">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-full bg-white dark:bg-surface-container-lowest flex items-center justify-center">
                    <Icon name="material-symbols:shopping-bag-outline" class="w-6 h-6 text-primary dark:text-indigo-400" />
                  </div>
                  <div>
                    <div class="text-sm font-bold text-on-surface">Apple Store</div>
                    <div class="text-[10px] text-on-surface-variant">2 mins ago</div>
                  </div>
                </div>
                <div class="text-sm font-bold text-on-surface">-$1,299.00</div>
              </div>
              <div class="p-3 bg-surface-container-low rounded-xl flex items-center justify-between dark:border dark:border-white/5">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-full bg-white dark:bg-surface-container-lowest flex items-center justify-center">
                    <Icon name="material-symbols:restaurant" class="w-6 h-6 text-tertiary" />
                  </div>
                  <div>
                    <div class="text-sm font-bold text-on-surface">Blue Bottle</div>
                    <div class="text-[10px] text-on-surface-variant">Today, 9:41 AM</div>
                  </div>
                </div>
                <div class="text-sm font-bold text-on-surface">-$6.50</div>
              </div>
              <div class="p-3 bg-surface-container-low rounded-xl flex items-center justify-between opacity-50 dark:border dark:border-white/5">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-full bg-white dark:bg-surface-container-lowest flex items-center justify-center">
                    <Icon name="material-symbols:transportation-outline" class="w-6 h-6 text-secondary" />
                  </div>
                  <div>
                    <div class="text-sm font-bold text-on-surface">Uber Trip</div>
                    <div class="text-[10px] text-on-surface-variant">Yesterday</div>
                  </div>
                </div>
                <div class="text-sm font-bold text-on-surface">-$24.12</div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <!-- Decorative blurs -->
      <div class="absolute -top-12 -right-12 w-64 h-64 bg-primary/5 dark:bg-primary/10 rounded-full blur-3xl -z-10"></div>
      <div class="absolute -bottom-12 -left-12 w-64 h-64 bg-tertiary/5 dark:bg-indigo-500/10 rounded-full blur-3xl -z-10"></div>
    </div>
  </div>
</section>
