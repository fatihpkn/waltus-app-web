---

<nav class="fixed top-0 w-full z-50 bg-surface-container-lowest/80 backdrop-blur-xl border-b border-outline-variant/20 dark:border-white/5">
  <div class="flex justify-between items-center px-6 md:px-8 py-5 max-w-7xl mx-auto w-full">
    <div class="flex items-center gap-2">
      <a href="/" class="text-2xl font-bold tracking-tighter text-on-surface no-underline">
        Waltus
      </a>
    </div>
    <div class="hidden md:flex items-center gap-8">
      <a class="font-headline tracking-tight text-sm font-semibold text-primary border-b-2 border-primary pb-1 no-underline" href="#">Product</a>
      <a class="font-headline tracking-tight text-sm font-medium text-on-surface-variant hover:text-primary transition-colors no-underline" href="#">Philosophy</a>
      <a class="font-headline tracking-tight text-sm font-medium text-on-surface-variant hover:text-primary transition-colors no-underline" href="#">Features</a>
      <a class="font-headline tracking-tight text-sm font-medium text-on-surface-variant hover:text-primary transition-colors no-underline" href="#">Pricing</a>
    </div>
    <div class="flex items-center gap-4">
      <button
        id="theme-toggle"
        aria-label="Toggle dark/light mode"
        class="w-9 h-9 flex items-center justify-center rounded-full text-on-surface-variant hover:text-primary hover:bg-surface-container transition-colors cursor-pointer"
      >
        <span id="theme-icon" class="material-symbols-outlined text-[20px]">light_mode</span>
      </button>
      <button class="px-6 py-2.5 rounded-full primary-gradient text-white font-semibold text-sm hover:opacity-90 transition-opacity cursor-pointer">
        Get Started
      </button>
    </div>
  </div>
</nav>

<script>
  (function () {
    var btn = document.getElementById('theme-toggle');
    var icon = document.getElementById('theme-icon');

    function isDark() {
      return document.documentElement.classList.contains('dark');
    }

    function updateIcon() {
      if (icon) {
        icon.textContent = isDark() ? 'dark_mode' : 'light_mode';
      }
    }

    updateIcon();

    if (btn) {
      btn.addEventListener('click', function () {
        if (isDark()) {
          document.documentElement.classList.remove('dark');
          localStorage.setItem('theme', 'light');
        } else {
          document.documentElement.classList.add('dark');
          localStorage.setItem('theme', 'dark');
        }
        updateIcon();
      });
    }
  })();
</script>
