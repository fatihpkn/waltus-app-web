---
const cards = [
  {
    title: 'Seamless Transitions',
    description: 'Move between accounts with a single swipe. No loading screens, no friction.',
    offset: '',
  },
  {
    title: 'Virtual Envelopes',
    description: 'Organize your capital into intent-based containers without opening new accounts.',
    offset: 'lg:mt-12',
  },
  {
    title: 'Intelligent Forecasting',
    description: "Know exactly where you'll be in 30 days based on your real-world behavior.",
    offset: 'lg:mt-24',
  },
];
---

<section class="bg-surface-container-lowest py-32 px-6 overflow-hidden">
  <div class="max-w-7xl mx-auto space-y-20">
    <div class="max-w-2xl">
      <h2 class="text-5xl font-extrabold tracking-tight mb-6 text-on-surface">The Wallet in your Pocket</h2>
      <p class="text-xl text-on-surface-variant">
        Experience a flow that feels as natural as breathing. We've reimagined banking as a personal,
        high-end tool for the modern professional.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
      {cards.map((card) => (
        <div class={`space-y-6 ${card.offset}`}>
          <div class="aspect-[4/5] bg-surface-container-low rounded-3xl p-10 flex flex-col justify-end relative group overflow-hidden dark:border dark:border-white/5">
            <!-- Gradient overlay for text legibility -->
            <div class="absolute inset-0 bg-gradient-to-t from-surface-container-low via-surface-container-low/30 to-transparent"></div>
            <!-- Decorative background blob -->
            <div class="absolute inset-0 opacity-10 dark:opacity-20 bg-gradient-to-br from-primary/40 to-tertiary/20 transition-transform duration-700 group-hover:scale-110"></div>
            <div class="relative z-10 space-y-3">
              <h3 class="text-2xl font-bold text-on-surface">{card.title}</h3>
              <p class="text-on-surface-variant">{card.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
