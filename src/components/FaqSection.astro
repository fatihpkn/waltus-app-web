---
const faqs = [
  {
    icon: 'security',
    question: 'Is my data secure with Waltus?',
    answer:
      'We use 256-bit AES encryption and multi-factor authentication for every interaction. Your security is our absolute priority, handled with institutional-grade rigor.',
  },
  {
    icon: 'account_balance',
    question: 'Can I connect all my bank accounts?',
    answer:
      'Yes. Waltus aggregates data from over 12,000 financial institutions globally, providing a single source of truth for your entire net worth.',
  },
  {
    icon: 'payments',
    question: 'Are there any hidden fees?',
    answer:
      'No. We believe in total clarity. Our pricing is transparent and fixed, with no hidden transactional costs or surprise renewals.',
  },
];
---

<section class="bg-surface-container-low py-32 px-6">
  <div class="max-w-3xl mx-auto space-y-16">
    <div class="text-center">
      <h2 class="text-4xl font-extrabold tracking-tight text-on-surface">Common Questions</h2>
    </div>
    <div class="space-y-4">
      {faqs.map((faq) => (
        <div class="bg-surface-container-lowest rounded-2xl p-6 editorial-shadow flex items-start gap-4 dark:border dark:border-white/5">
          <span class="material-symbols-outlined text-primary dark:text-indigo-400">{faq.icon}</span>
          <div>
            <h4 class="font-bold mb-2 text-on-surface">{faq.question}</h4>
            <p class="text-on-surface-variant text-sm leading-relaxed">{faq.answer}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
