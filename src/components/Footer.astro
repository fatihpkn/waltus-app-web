---
import { Icon } from 'astro-icon/components';
---

<footer class="bg-surface-container-low w-full">
  <div class="grid grid-cols-1 md:grid-cols-4 gap-12 px-8 md:px-12 py-20 max-w-7xl mx-auto w-full">
    <div class="space-y-6">
      <span class="text-xl font-bold text-on-surface">Waltus</span>
      <p class="text-on-surface-variant text-sm leading-relaxed">The Financial Sanctuary. Curated for those who demand clarity and intellectual calm.</p>
    </div>
    <div class="space-y-4">
      <h5 class="font-headline text-xs tracking-wide uppercase font-semibold text-primary">Product</h5>
      <ul class="space-y-2 list-none p-0 m-0">
        <li><a class="font-headline text-xs tracking-wide uppercase font-semibold text-on-surface-variant hover:text-primary transition-colors no-underline" href="#">Features</a></li>
        <li><a class="font-headline text-xs tracking-wide uppercase font-semibold text-on-surface-variant hover:text-primary transition-colors no-underline" href="#">Security</a></li>
        <li><a class="font-headline text-xs tracking-wide uppercase font-semibold text-on-surface-variant hover:text-primary transition-colors no-underline" href="#">Status</a></li>
      </ul>
    </div>
    <div class="space-y-4">
      <h5 class="font-headline text-xs tracking-wide uppercase font-semibold text-primary">Legal</h5>
      <ul class="space-y-2 list-none p-0 m-0">
        <li><a class="font-headline text-xs tracking-wide uppercase font-semibold text-on-surface-variant hover:text-primary transition-colors no-underline" href="#">Privacy Policy</a></li>
        <li><a class="font-headline text-xs tracking-wide uppercase font-semibold text-on-surface-variant hover:text-primary transition-colors no-underline" href="#">Terms of Service</a></li>
      </ul>
    </div>
    <div class="space-y-4">
      <h5 class="font-headline text-xs tracking-wide uppercase font-semibold text-primary">Connect</h5>
      <ul class="space-y-2 list-none p-0 m-0">
        <li><a class="font-headline text-xs tracking-wide uppercase font-semibold text-on-surface-variant hover:text-primary transition-colors no-underline" href="#">Contact</a></li>
        <li><a class="font-headline text-xs tracking-wide uppercase font-semibold text-on-surface-variant hover:text-primary transition-colors no-underline" href="#">Twitter</a></li>
      </ul>
    </div>
  </div>
  <div class="px-8 md:px-12 py-10 max-w-7xl mx-auto w-full border-t border-outline-variant/30 flex flex-col md:flex-row justify-between items-center gap-6">
    <span class="font-headline text-xs tracking-wide uppercase font-semibold text-on-surface-variant">
      &copy; {new Date().getFullYear()} Waltus Financial. Curated for Intellectual Calm.
    </span>
    <div class="flex gap-8">
      <Icon name="material-symbols:eco-outline" class="w-6 h-6 text-on-surface-variant" />
      <Icon name="material-symbols:language" class="w-6 h-6 text-on-surface-variant" />
    </div>
  </div>
</footer>
