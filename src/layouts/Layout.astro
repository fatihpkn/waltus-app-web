---
import BaseHead from '../components/BaseHead.astro';
import NavBar from '../components/NavBar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
}

const { title, description, image } = Astro.props;
const openPanelClientId = import.meta.env.PUBLIC_OPENPANEL_CLIENT_ID?.trim();
---

<html lang="en">
  <head>
    <!-- Anti-flash: apply dark class before first paint based on stored or system preference -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    {openPanelClientId && (
      <>
        <script is:inline define:vars={{ openPanelClientId }}>
          window.op = window.op || function () {
            var queue = [];
            return new Proxy(function () {
              if (arguments.length) {
                queue.push([].slice.call(arguments));
              }
            }, {
              get: function (_target, key) {
                if (key === 'q') {
                  return queue;
                }

                return function () {
                  queue.push([key].concat([].slice.call(arguments)));
                };
              },
              has: function (_target, key) {
                return key === 'q';
              }
            });
          }();

          window.op('init', {
            clientId: openPanelClientId,
            trackScreenViews: true,
            trackOutgoingLinks: true,
            trackAttributes: true,
          });
        </script>
        <script src="https://openpanel.dev/op1.js" defer async></script>
      </>
    )}
    <BaseHead title={title} description={description} image={image} />
  </head>
  <body class="bg-surface text-on-surface">
    <NavBar />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
