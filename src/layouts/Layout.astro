---
import BaseHead from '../components/BaseHead.astro';
import NavBar from '../components/NavBar.astro';
import Footer from '../components/Footer.astro';
import { OpenPanelComponent } from '@openpanel/astro';
import { env } from 'cloudflare:workers';

interface Props {
  title: string;
  description: string;
  image?: string;
}

const { title, description, image } = Astro.props;
const openPanelClientId = env.PUBLIC_OPENPANEL_CLIENT_ID?.trim();
---

<html lang="en">
  <head>
    <!-- Anti-flash: apply dark class before first paint based on stored or system preference -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    {openPanelClientId && (
      <OpenPanelComponent
        clientId={openPanelClientId}
        apiUrl="https://w-openpanel.waltusapp.com"
        scriptUrl="https://w-openpanel.waltusapp.com/op1.js"
        trackScreenViews={true}
        trackOutgoingLinks={true}
        trackAttributes={true}
      />
    )}
    <BaseHead title={title} description={description} image={image} />
  </head>
  <body class="bg-surface text-on-surface">
    <NavBar />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
